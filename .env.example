# MyCellar environment template.
# Never put real secrets in this file.
# Production values must live in Vercel environment variables and in the
# approved password vault as the administrative source of truth.

# Database / Neon / Postgres
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL_NO_SSL=
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
PGHOST=
PGHOST_UNPOOLED=
PGDATABASE=
PGUSER=
PGPASSWORD=
NEON_PROJECT_ID=
NEON_AUTH_BASE_URL=
VITE_NEON_AUTH_URL=

# AI
OPENAI_API_KEY=

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_URL=
MERCADO_PAGO_WEBHOOK_SECRET=
MYCELLAR_PUBLIC_URL=
APP_PUBLIC_URL=

# Email login
RESEND_API_KEY=
AUTH_EMAIL_FROM=
EMAIL_LOGIN_PEPPER=

# Google login
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Closed beta / Pro access
MYCELLAR_PRO_EMAILS=
MYCELLAR_PRO_USER_IDS=
MYCELLAR_DEFAULT_PLAN=
LEGACY_CELLAR_IMPORT_EMAILS=

# Waitlist/report
WAITLIST_REPORT_TOKEN=

# Object storage
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# Runtime / build
BASE_PATH=/
PORT=3000
NODE_ENV=
LOG_LEVEL=
MYCELLAR_MARKET=
VITE_MYCELLAR_MARKET=
NX_DAEMON=
TURBO_CACHE=
TURBO_DOWNLOAD_LOCAL_ENABLED=
TURBO_REMOTE_ONLY=
TURBO_RUN_SUMMARY=
